    "# Merge load + temperature\n",
    "merged = pd.merge(daily_peak, temp_daily[['date','zone','tmax_f']],\n",
    "                  on=['date','zone'], how='inner')\n",
    "\n",
    "# Heat wave flag: runs of >= 3 consecutive days >= 95 F\n",
    "def flag_heat_waves(series, thresh=HEAT_THRESH, min_days=3):\n",
    "    hot = (series >= thresh).astype(int)\n",
    "    in_wave = pd.Series(False, index=series.index)\n",
    "    run = 0\n",
    "    run_start = None\n",
    "    for i in series.index:\n",
    "        if hot[i]:\n",
    "            if run == 0:\n",
    "                run_start = i\n",
    "            run += 1\n",
    "        else:\n",
    "            if run >= min_days:\n",
    "                in_wave.loc[run_start:i-1] = True\n",
    "            run = 0\n",
    "            run_start = None\n",
    "    if run >= min_days:\n",
    "        in_wave.loc[run_start:] = True\n",
    "    return in_wave\n",
    "\n",
    "merged = merged.sort_values(['zone','date']).reset_index(drop=True)\n",
    "hw_flags = []\n",
    "for zone, grp in merged.groupby('zone', sort=False):\n",
    "    hw_flags.append(flag_heat_waves(grp['tmax_f'].reset_index(drop=True)))\n",
    "\n",
    "merged['heat_wave'] = list(itertools.chain.from_iterable(hw_flags))\n",
    "\n",
    "# Temperature anomaly relative to zone mean (simple baseline)\n",
    "zone_means = merged.groupby('zone')['tmax_f'].transform('mean')\n",
    "merged['tmax_anom'] = merged['tmax_f'] - zone_means\n",
    "\n",
    "print(f\"Merged: {len(merged):,} zone-days | date range: {merged.date.min().date()} to {merged.date.max().date()}\")\n",
    "print()\n",
    "hw_summary = merged.groupby('zone').agg(\n",
    "    total_days=('heat_wave','count'),\n",
    "    hw_days=('heat_wave','sum')\n",
    ")\n",
    "hw_summary['hw_pct'] = (hw_summary['hw_days'] / hw_summary['total_days'] * 100).round(1)\n",
    "print(hw_summary)"
   ]
