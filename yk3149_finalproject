    "def bootstrap_diff_ci(hw_vals, non_vals, n_boot=1000, ci=95):\n",
    "    diffs = [np.mean(np.random.choice(hw_vals,  len(hw_vals),  replace=True)) -\n",
    "             np.mean(np.random.choice(non_vals, len(non_vals), replace=True))\n",
    "             for _ in range(n_boot)]\n",
    "    lo = np.percentile(diffs, (100-ci)/2)\n",
    "    hi = np.percentile(diffs, 100-(100-ci)/2)\n",
    "    return np.mean(diffs), lo, hi\n",
    "\n",
    "abs_deltas, pct_deltas, err_los, err_his = [], [], [], []\n",
    "\n",
    "for zone in ZONES_ORDERED:\n",
    "    grp      = merged[merged['zone'] == zone]\n",
    "    hw_vals  = grp[grp['heat_wave']]['peak_mw'].values\n",
    "    non_vals = grp[~grp['heat_wave']]['peak_mw'].values\n",
    "    base     = np.mean(non_vals)\n",
    "    mean_diff, ci_lo, ci_hi = bootstrap_diff_ci(hw_vals, non_vals)\n",
    "    abs_deltas.append(mean_diff)\n",
    "    pct_deltas.append(mean_diff / base * 100)\n",
    "    err_los.append(mean_diff - ci_lo)\n",
    "    err_his.append(ci_hi - mean_diff)\n",
    "\n",
    "colors = ['#E53935' if z == 'DOM' else '#42A5F5' for z in ZONES_ORDERED]\n",
