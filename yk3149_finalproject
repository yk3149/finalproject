    "    }\n",
    "    dates_d = pd.date_range(START_DATE, END_DATE, freq='D')\n",
    "    frames_t = []\n",
    "    for zone, (july_mean, jan_mean, sd) in station_clim.items():\n",
    "        doy = dates_d.day_of_year.values\n",
    "        amp = (july_mean - jan_mean) / 2\n",
    "        mid = (july_mean + jan_mean) / 2\n",
    "        seasonal = mid + amp * np.sin((doy - 80) * 2 * np.pi / 365)\n",
    "        # Year-to-year variability\n",
    "        yr_anom = {y: np.random.normal(0, 1.5) for y in range(2018, 2024)}\n",
    "        yr_arr  = np.array([yr_anom[d.year] for d in dates_d])\n",
    "        # AR(1) daily noise\n",
    "        noise = np.zeros(len(dates_d))\n",
    "        noise[0] = np.random.normal(0, sd)\n",
    "        for i in range(1, len(dates_d)):\n",
