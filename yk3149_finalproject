    "\n",
    "# ------------------------------------------------------------------\n",
    "# Synthetic dataset -- calibrated to PJM annual reports 2018-2023\n",
    "# Parameters: (base_mw, summer_amplitude, dc_extra_base, noise_std)\n",
    "# ------------------------------------------------------------------\n",
    "zone_params = {\n",
    "    'DOM':  (10500, 4500, 800, 350),\n",
    "    'PSEG': ( 7800, 3200, 100, 280),\n",
    "    'PPL':  ( 8200, 3000, 100, 300),\n",
    "    'BGE':  ( 5600, 2100, 150, 200),\n",
    "    'PECO': ( 7100, 2800, 100, 260),\n",
    "}\n",
    "\n",
    "dates_h = pd.date_range(START_DATE, END_DATE, freq='h')\n",
    "frames  = []\n",
    "for zone, (base, s_amp, dc_extra, noise_sd) in zone_params.items():\n",
    "    doy  = dates_h.day_of_year.values\n",
    "    hour = dates_h.hour.values\n",
    "    # Seasonal peak ~Aug 1 (doy 213)\n",
    "    seasonal = s_amp * np.sin(np.clip((doy - 80) * 2 * np.pi / 365, 0, None)) ** 2\n",
    "    # Diurnal cycle, peak ~15:00\n",
    "    diurnal  = 1200 * np.sin((hour - 5) * np.pi / 14) * ((hour >= 6) & (hour <= 22))\n",
    "    # Continuous data-center base (DOM only)\n",
    "    dc_base  = dc_extra if zone == 'DOM' else 0\n",
    "    # AR(1) noise for temporal autocorrelation\n",
    "    noise = np.zeros(len(dates_h))\n",
    "    noise[0] = np.random.normal(0, noise_sd)\n",
    "    for i in range(1, len(dates_h)):\n",
    "        noise[i] = 0.55 * noise[i-1] + np.random.normal(0, noise_sd * 0.83)\n",
    "    # Slight year-over-year growth\n",
    "    trend = 40 * (dates_h.year.values - 2018)\n",
    "    load  = np.clip(base + seasonal + diurnal + dc_base + noise + trend,\n",
    "                    base * 0.5, base * 2.5)\n",
    "    frames.append(pd.DataFrame({'datetime': dates_h, 'zone': zone, 'load_mw': load}))\n",
    "\n",
    "hourly_raw = pd.concat(frames, ignore_index=True)\n",
    "print(f\"Hourly data: {len(hourly_raw):,} rows | zones: {sorted(hourly_raw.zone.unique())}\")\n",
    "print(hourly_raw.groupby('zone')['load_mw'].agg(['min','mean','max']).round(0))"
